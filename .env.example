# =============================================================================
# 经济日历技能 - 配置示例
# =============================================================================
# 用途：API 和推送配置模板
# 注意：复制此文件为 .env 后填写真实配置
# =============================================================================

# -----------------------------------------------------------------------------
# 数据源配置
# -----------------------------------------------------------------------------

# Forex Factory API (传统金融事件)
# 说明：无需 API Key，直接访问官方 JSON 接口
# 文档：https://www.forexfactory.com/calendar
FOREX_FACTORY_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json

# CoinMarketCal API (币圈事件) - PRIMARY
# 说明：加密货币事件日历
# 文档：https://coinmarketcal.com/en/doc
# 获取：注册账号后在个人中心获取 API Key
COINMARKETCAL_API_KEY=your_coinmarketcal_api_key_here

# Coindar API (币圈事件) - BACKUP
# 说明：备用数据源，等待 API Key 审核
# 文档：https://coindar.org/zh-cn/api
# 状态：⏳ 审核中
COINDAR_API_KEY=your_coindar_api_key_here

# -----------------------------------------------------------------------------
# 推送渠道配置
# -----------------------------------------------------------------------------

# 飞书推送配置
# 说明：填写你的飞书渠道配置
# 格式：渠道名称（在 openclaw.json 中配置的渠道）
FEISHU_CHANNEL=feishu
FEISHU_TARGET=your_feishu_target_here

# Telegram 推送配置
# 说明：填写你的 Telegram Bot 配置
# 格式：用户 ID 或频道 ID
TELEGRAM_CHANNEL=telegram
TELEGRAM_TARGET=your_telegram_target_here

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------

# 时区配置
# 说明：推送时间基于此时区
# 默认：Asia/Shanghai (北京时间 UTC+8)
TIMEZONE=Asia/Shanghai

# 输出目录
# 说明：生成的日历文件保存位置
# 默认：shared/02_outbox/
OUTPUT_DIR=/path/to/your/output/dir

# -----------------------------------------------------------------------------
# 使用说明
# -----------------------------------------------------------------------------
# 1. 复制此文件：cp .env.example .env
# 2. 编辑 .env 文件，填写真实配置
# 3. 切勿将 .env 文件上传到 Git！
# 4. .env 文件已添加到 .gitignore，自动排除
# -----------------------------------------------------------------------------
